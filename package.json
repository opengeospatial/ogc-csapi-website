{
    "title": "OGC API - Connected Systems micro website",
    "name": "ogc-csapi-website",
    "version": "0.1.0",
    "scripts": {
        "build": "npm run clean && npm run build:pug && npm run build:scss && npm run build:scripts && npm run build:assets && npm run copy:cname",
        "build:assets": "node scripts/build-assets.js",
        "build:pug": "node scripts/build-pug.js",
        "build:scripts": "node scripts/build-scripts.js",
        "build:scss": "node scripts/build-scss.js",
        "clean": "node scripts/clean.js",
        "copy:cname": "node -e \"const fs=require('fs');if(fs.existsSync('CNAME'))fs.copyFileSync('CNAME','dist/CNAME')\"",
        "start": "npm run build && node scripts/start.js",
        "start:debug": "npm run build && node scripts/start-debug.js"
    },
    "description": "Source code for the OGC API - Connected Systems micro website.",
    "keywords": [
        "ogc",
        "connected-systems",
        "csapi",
        "sensorml",
        "swe-common",
        "standards",
        "OpenAPI",
        "developer"
    ],
    "homepage": "https://csapi.developer.ogc.org/",
    "bugs": {
        "url": "https://github.com/opengeospatial/ogc-csapi-website/issues/",
        "email": "devrel@ogc.org"
    },
    "author": "Joana Simoes",
    "contributors": [
        "doublebyte1 (https://github.com/doublebyte1/)"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/opengeospatial/ogc-csapi-website.git"
    },
    "dependencies": {
        "bootstrap": "5.0.2"
    },
    "devDependencies": {
        "autoprefixer": "10.2.6",
        "browser-sync": "^3.0.3",
        "chokidar": "3.5.2",
        "concurrently": "6.2.0",
        "postcss": "^8.4.41",
        "prettier": "2.3.2",
        "pug": "^3.0.3",
        "sass": "1.35.1",
        "shelljs": "^0.8.5",
        "upath": "2.0.1"
    }
}
